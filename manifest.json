{
  "manifest_version": 3,
  "name": "Request Formatter for DevTools",
  "version": "0.2.0",
  "description": "Format request and response payloads directly inside Chrome DevTools.",
  "devtools_page": "devtools.html",
  "permissions": ["clipboardWrite"],
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  }
}
